nums = [1,2,2,3,2,3,1,4,5,5,5,6,2,2,2,3,4,5]

k = 3

def count_frequencies(arr, k):
    freq = {}
    for element in arr:
        freq[element] = freq.get(element, 0) + 1
        sorted_freq = dict(sorted(freq.items(), key=lambda x: x[1], reverse=True))
        top_k = list(sorted_freq.keys())[:k]

    return top_k, sorted_freq

print(count_frequencies(nums, k))


